# Copy this file to .env and fill in real values before running in production.
# Never commit .env — it is gitignored.

SPRING_PROFILES_ACTIVE=prod

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/orque_crm
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# JWT — generate with: openssl rand -base64 64
APP_JWT_SECRET=

# License encryption — must match OPAC values exactly
CRM_LICENSE_SECRET=
CRM_LICENSE_IV_HEX=

# OPAC backend URL
OPAC_BASE_URL=http://localhost:8082

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
